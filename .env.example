# Example environment file. Copy to .env and fill in real values.
# NEVER commit the real .env — it is git-ignored. Values here are placeholders only.

# --- Cloudflare (DNS for the 6 site domains; mail/MX records are NOT managed here) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=

# --- AWS (EC2, S3 remote state, ECR Public auth) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional. Required only when using temporary AWS credentials (STS/session credentials).
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_MEDIA_URL=

# Terraform remote state uses native S3 locking (use_lockfile); no DynamoDB table needed.

# --- Amazon ECR Public (image registry; pull source) ---
# Registry alias only, e.g. public.ecr.aws/<alias>
ECR_PUBLIC_ALIAS=

# --- EC2 access (uses the project SSH key pair below, not a personal key) ---
EC2_HOST=

# --- Project SSH key pair (stored in .ssh/, git-ignored) ---
# Paths only — never paste key material into env files.
PROJECT_SSH_PRIVATE_KEY=.ssh/project_key
PROJECT_SSH_PUBLIC_KEY=.ssh/project_key.pub

# --- GitHub repository_dispatch (PAT with repo scope on infra-repo) ---
INFRA_REPO_DISPATCH_TOKEN=

# --- GitHub Actions secrets sync (PAT with repo scope; used by `--phase secrets`) ---
# If empty, the secrets phase falls back to INFRA_REPO_DISPATCH_TOKEN.
GITHUB_TOKEN=

# --- Managed domains (one per app-repo) ---
DOMAIN_1=buyraq.com
DOMAIN_2=codehelp.pp.ua
DOMAIN_3=cosmeticpro.pp.ua
DOMAIN_4=ddnsteltonicka.pp.ua
DOMAIN_5=solovkadmytro.pp.ua
DOMAIN_6=solovkaskincare.pp.ua
